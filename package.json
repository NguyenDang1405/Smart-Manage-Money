{
  "name": "smart-money-manager",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "puppeteer": "^25.0.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.1.0",
      "@types/react-dom": "~19.1.0",
      "expo-crypto": "~15.0.9"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19.1.0",
        "react-dom": "19.1.0"
      }
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2"
  }
}
